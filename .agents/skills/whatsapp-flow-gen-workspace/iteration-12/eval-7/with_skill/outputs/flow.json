{
  "version": "7.1",
  "screens": [
    {
      "id": "CATEGORIES_SCREEN",
      "title": "Main Categories",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "NavigationList",
            "name": "category_list",
            "list-items": [
              {
                "id": "cat_1",
                "main-content": {
                  "title": "Technical Support",
                  "description": "Hardware and Software"
                },
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "screen": "HELP_SCREEN",
                    "payload": {
                      "category": "Technical Support"
                    }
                  }
                }
              },
              {
                "id": "cat_2",
                "main-content": {
                  "title": "Billing",
                  "description": "Invoices and Payments"
                },
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "screen": "HELP_SCREEN",
                    "payload": {
                      "category": "Billing"
                    }
                  }
                }
              },
              {
                "id": "cat_3",
                "main-content": {
                  "title": "Account Settings",
                  "description": "Profile and Privacy"
                },
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "screen": "HELP_SCREEN",
                    "payload": {
                      "category": "Account Settings"
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "HELP_SCREEN",
      "title": "Help Instructions",
      "terminal": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Help Center"
          },
          {
            "type": "TextBody",
            "text": "You have selected: ${data.category}. \n\nPlease follow the instructions below to resolve your issue. If you need further assistance, please contact our support team.",
            "markdown": true
          },
          {
            "type": "TextBody",
            "text": "1. Check our FAQ section.\n2. Verify your internet connection.\n3. Restart your device if necessary.",
            "markdown": true
          },
          {
            "type": "Footer",
            "label": "Finish",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "status": "help_read",
                "category": "${data.category}"
              }
            }
          }
        ]
      }
    }
  ]
}
