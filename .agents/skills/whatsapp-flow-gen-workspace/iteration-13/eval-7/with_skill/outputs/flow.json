{
  "version": "7.1",
  "screens": [
    {
      "id": "CATEGORY_SELECTION",
      "title": "Select Category",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "NavigationList",
            "name": "category_list",
            "label": "Help Categories",
            "list-items": [
              {
                "id": "account_help",
                "main-content": {
                  "title": "Account Help",
                  "description": "Login and profile"
                },
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "screen": "HELP_SCREEN",
                    "payload": {
                      "category": "Account Help",
                      "instructions": "To manage your account, go to Settings > Profile. You can update your email, password, and notification preferences there."
                    }
                  }
                }
              },
              {
                "id": "billing_help",
                "main-content": {
                  "title": "Billing Help",
                  "description": "Payments and plans"
                },
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "screen": "HELP_SCREEN",
                    "payload": {
                      "category": "Billing Help",
                      "instructions": "For billing inquiries, visit the Billing section in your dashboard. You can view invoices, change your payment method, or upgrade your plan."
                    }
                  }
                }
              },
              {
                "id": "general_help",
                "main-content": {
                  "title": "General Help",
                  "description": "Other questions"
                },
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "screen": "HELP_SCREEN",
                    "payload": {
                      "category": "General Help",
                      "instructions": "If you have any other questions, please contact our support team at support@example.com or visit our online help center."
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "HELP_SCREEN",
      "title": "${data.category}",
      "terminal": true,
      "data": {
        "category": {
          "type": "string",
          "__example__": "Account Help"
        },
        "instructions": {
          "type": "string",
          "__example__": "Sample help instructions."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "${data.category}"
          },
          {
            "type": "TextBody",
            "text": "${data.instructions}",
            "markdown": true
          },
          {
            "type": "Footer",
            "label": "Finished",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "selected_category": "${data.category}"
              }
            }
          }
        ]
      }
    }
  ]
}
